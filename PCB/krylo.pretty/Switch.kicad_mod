		)
	)
	(model "${KIPRJMOD}/krylo.pretty/keycap.step"
		(offset
			(xyz 0 0 7.5)
		)
		(scale
			(xyz 1 1 1)
		)
		(rotate
			(xyz -90 -0 -0)
		)
	)
	(model "${KIPRJMOD}/krylo.pretty/hot_swap_socket.step"
		(offset
			(xyz 0 0 2.25)
		)
		(scale
			(xyz 1 1 1)
		)
		(rotate
			(xyz -0 -0 -180)
		)
	)
)
